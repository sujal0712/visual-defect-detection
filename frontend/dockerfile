# 1. Base Image (Lightweight Python)
FROM python:3.11-slim

# 2. Set the working directory inside the container
WORKDIR /app

# 3. Copy only the requirements first (to leverage Docker caching)
COPY requirements.txt .

# 4. Install the frontend dependencies
RUN pip install --no-cache-dir -r requirements.txt

# 5. Copy the actual Streamlit dashboard code
COPY streamlit_app.py .

# 6. Expose port 8501 (Streamlit's default port)
EXPOSE 8501

# 7. Add a Healthcheck to ensure the UI is actually running
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8501/_stcore/health')" || exit 1

# 8. Command to boot up Streamlit
CMD ["streamlit", "run", "streamlit_app.py", "--server.port=8501", "--server.address=0.0.0.0"]